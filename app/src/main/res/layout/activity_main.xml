<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Slim header: nav icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/settingsBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_settings"
                android:tint="#CCCCCC"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings_title"/>

            <ImageView
                android:id="@+id/aboutBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_info"
                android:tint="#CCCCCC"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/about_title"/>

        </LinearLayout>

        <!-- Combined Status + IP Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <!-- status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/dot_gray"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_idle"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/refreshBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/refresh"
                    android:textColor="#00E676"
                    android:textSize="14sp"
                    android:padding="6dp"/>

            </LinearLayout>

            <!-- region (big) -->
            <TextView
                android:id="@+id/regionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"/>

            <!-- ip · isp (small) -->
            <TextView
                android:id="@+id/ipText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ip_unknown"
                android:textColor="#888888"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"/>

            <!-- ping -->
            <TextView
                android:id="@+id/pingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Toggle Button -->
        <Button
            android:id="@+id/toggleBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_start"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#00E676"
            android:layout_marginBottom="20dp"/>

        <!-- Log Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/log_title"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/clearLogBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear"
                    android:textColor="#FF5252"
                    android:textSize="13sp"
                    android:padding="4dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/countdownText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"/>

            <!-- Latency trend chart -->
            <org.shuttlelab.netpulse.LatencyChartView
                android:id="@+id/latencyChart"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/logEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/log_empty"
                android:textColor="#666666"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <ListView
                android:id="@+id/logList"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:divider="#222222"
                android:dividerHeight="1dp"
                android:nestedScrollingEnabled="true"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
